<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_pantalla"
    android:fitsSystemWindows="true">

    <!-- BARRA SUPERIOR (Corrección de fondo transparente aplicada) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/fondo_pantalla">

        <ImageButton
            android:id="@+id/btnVolverElectricidad"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/texto_principal"
            android:contentDescription="Volver" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Electricidad"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/texto_principal"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/fondo_tarjeta"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selecciona tu compañía"
                        android:textSize="12sp"
                        android:textColor="@color/texto_secundario"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <Spinner
                            android:id="@+id/spinnerCompania"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/fondo_spinner"/>

                        <ImageButton
                            android:id="@+id/btnOpcionesEnergia"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="8dp"
                            android:src="@android:drawable/ic_menu_preferences"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/texto_secundario"
                            android:contentDescription="Opciones de Energía" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Precio Actual"
                        android:textSize="14sp"
                        android:textColor="@color/texto_secundario"
                        android:textStyle="bold"
                        android:textAllCaps="true"/>

                    <TextView
                        android:id="@+id/tvPrecioActual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- €"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:textColor="@color/texto_principal"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- SOLUCIÓN 1: MARCO BLANCO PARA EL LOGO -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:id="@+id/ivLogoFuente"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:padding="8dp"
                            android:scaleType="fitCenter"
                            android:contentDescription="Logo Compañía"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tvNombreFuente"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cargando..."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/texto_secundario"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnVer24h"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Ver gráfica 24 horas"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp"/>

            <!-- CONTENEDOR DE LA GRÁFICA -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGrafica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/fondo_tarjeta"
                android:layout_marginBottom="24dp">

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartPrecios"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_margin="16dp"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
    <com.google.android.gms.ads.AdView
        xmlns:ads="http://schemas.android.com/apk/res-auto"
        android:id="@+id/adViewMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        ads:adSize="BANNER"
        ads:adUnitId="ca-app-pub-3940256099942544/6300978111" />
</LinearLayout>