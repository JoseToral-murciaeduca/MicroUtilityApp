<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_pantalla"
    android:fitsSystemWindows="true">

    <!-- BARRA SUPERIOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnVolverGas"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/texto_secundario"
            android:contentDescription="Volver" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gas Natural"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/texto_principal"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <!-- TARJETA PRINCIPAL -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/fondo_tarjeta">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecciona tu tarifa"
                android:textSize="12sp"
                android:textColor="@color/texto_secundario"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"/>

            <!-- CONTENEDOR HORIZONTAL: SPINNER + ENGRANAJE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <Spinner
                    android:id="@+id/spinnerGas"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/fondo_spinner"/>

                <ImageButton
                    android:id="@+id/btnOpcionesGas"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:src="@android:drawable/ic_menu_preferences"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/texto_secundario"
                    android:contentDescription="Opciones de Gas" />
            </LinearLayout>

            <!-- PRECIO VARIABLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Término Variable (Consumo)"
                android:textSize="14sp"
                android:textColor="@color/texto_secundario"
                android:textStyle="bold"
                android:textAllCaps="true"/>

            <TextView
                android:id="@+id/tvPrecioVariableGas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0430 €/kWh"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="@color/texto_principal"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"/>

            <!-- PRECIO FIJO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Término Fijo (Mensual)"
                android:textSize="14sp"
                android:textColor="@color/texto_secundario"
                android:textStyle="bold"
                android:textAllCaps="true"/>

            <TextView
                android:id="@+id/tvPrecioFijoGas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.26 €/mes"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#059669"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"/>

            <ImageView
                android:id="@+id/ivLogoGas"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:contentDescription="Logo Gas"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnConfigurarGas"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:text="Configurar mi tarifa libre"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"/>

</LinearLayout>