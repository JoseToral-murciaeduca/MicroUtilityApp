<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_pantalla"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnVolver"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/texto_secundario"
            android:contentDescription="Volver" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Combustible"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/texto_principal"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/fondo_tarjeta">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Llenar depósito estándar (50L)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/texto_secundario"
                android:textAllCaps="true"/>

            <TextView
                android:id="@+id/tvCosteLlenado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculando..."
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/texto_principal"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvGasolineraBarata"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buscando la opción más económica en 100 km..."
                android:textSize="14sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Estaciones de servicio cercanas (Menos de 100km)"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/texto_principal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"/>

    <ListView
        android:id="@+id/lvGasolineras"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"/>

</LinearLayout>