<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Buscador -->
    <EditText
        android:id="@+id/etBuscarCompania"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Buscar compañía..."
        android:inputType="text"
        android:padding="12dp"
        android:backgroundTint="@color/texto_secundario"
        android:layout_marginBottom="8dp"/>

    <!-- SOLUCIÓN 2: BOTONES DE SELECCIÓN MASIVA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnSeleccionarTodo"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seleccionar Todo"
            android:textSize="12sp"
            android:textColor="@color/texto_principal"
            android:textAllCaps="false"/>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/texto_secundario"
            android:layout_marginHorizontal="8dp"/>

        <Button
            android:id="@+id/btnDeseleccionarTodo"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deseleccionar Todo"
            android:textSize="12sp"
            android:textColor="@color/texto_principal"
            android:textAllCaps="false"/>
    </LinearLayout>

    <!-- Lista de compañías (con checkboxes) -->
    <ListView
        android:id="@+id/listViewCompanias"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="4dp"/>

</LinearLayout>